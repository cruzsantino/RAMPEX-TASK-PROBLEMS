class Solution {
    public int numWaterBottles(int numBottles, int numExchange) {
        int total=numBottles;
        while(numBottles>=numExchange)
        {
            int newb=numBottles/numExchange;
            int remb=numBottles%numExchange;
            total+=newb;
            numBottles=newb+remb;
        }
        return total;
    }
}
